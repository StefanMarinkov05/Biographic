@page
@model LogoutModel
@{
    ViewData["Title"] = "Изход";
}

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="text-center">
        <h2 class="text-danger fw-bold"><i class="bi bi-box-arrow-right"></i> Изход</h2>
        @if (User.Identity?.IsAuthenticated ?? false)
        {
            <form class="mt-3" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                <button type="submit" class="btn btn-danger">
                    <i class="bi bi-box-arrow-left"></i> Натисни тук за изход
                </button>
            </form>
        }
        else
        {
            <p class="mt-3 text-muted">Успешно излязохте от приложението.</p>
        }
    </div>
</div>
