@page
@model RegisterModel

@{
    ViewData["Title"] = "Регистрация";
}

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4 rounded-4" style="max-width: 400px; width: 100%;">
        <div class="text-center">
            <h2 class="mb-4 fw-bold text-success"><i class="bi bi-person-plus"></i> Регистрация</h2>
        </div>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.FirstName" class="form-control" placeholder="Име" />
                <label asp-for="Input.FirstName"><i class="bi bi-person"></i> Име</label>
                <span asp-validation-for="Input.FirstName" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.LastName" class="form-control" placeholder="Фамилия" />
                <label asp-for="Input.LastName"><i class="bi bi-person-badge"></i> Фамилия</label>
                <span asp-validation-for="Input.LastName" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Nickname" class="form-control" placeholder="Псевдоним" />
                <label asp-for="Input.Nickname"><i class="bi bi-person-lines-fill"></i> Псевдоним</label>
                <span asp-validation-for="Input.Nickname" class="text-danger"></span>
            </div>


            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                <label asp-for="Input.Email"><i class="bi bi-envelope"></i> Имейл</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password" type="password" class="form-control" autocomplete="new-password" placeholder="password" />
                <label asp-for="Input.Password"><i class="bi bi-key"></i> Парола</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control" autocomplete="new-password" placeholder="password" />
                <label asp-for="Input.ConfirmPassword"><i class="bi bi-check-circle"></i> Потвърди паролата</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-success w-100">
                <i class="bi bi-person-check"></i> Регистрирай се
            </button>

            <div class="text-center mt-3">
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none">
                    <i class="bi bi-box-arrow-in-left"></i> Вече имате акаунт? Вход
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
