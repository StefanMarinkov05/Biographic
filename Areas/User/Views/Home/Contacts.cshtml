@{
    ViewData["Title"] = "Контакти";
}

<div class="container py-5">
    <h1 class="display-5 text-center fw-bold mb-5">📞 Контакти</h1>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card shadow border-0 h-100 bg-light">
                <div class="card-body text-center">
                    <h4 class="card-title fw-bold mb-3">👤 Администратор</h4>
                    <p class="text-muted">Ако имате въпроси, свържете се с нас директно.</p>

                    <p><i class="bi bi-envelope-at-fill text-danger"></i> <strong>Имейл:</strong> <a href="mailto:admin@sudo.com" class="text-decoration-none">admin@sudo.com</a></p>
                    <p><i class="bi bi-telephone-fill text-success"></i> <strong>Телефон:</strong> <a href="tel:+359425609584" class="text-decoration-none">+359 42 560 9584</a></p>
                    <p><i class="bi bi-geo-alt-fill text-primary"></i> <strong>Адрес:</strong> Пазарджик, България</p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow border-0 h-100">
                <div class="card-body">
                    <h4 class="card-title fw-bold text-center mb-3">🧑‍💼 Предложи нова личност</h4>
                    <p class="text-muted text-center">Добавете интересна личност към нашата база.</p>

                    <form>
                        <div class="mb-3">
                            <label for="yourName" class="form-label">Вашето име</label>
                            <input type="text" class="form-control" id="yourName" placeholder="Име" required />
                        </div>
                        <div class="mb-3">
                            <label for="yourEmail" class="form-label">Вашият имейл</label>
                            <input type="email" class="form-control" id="yourEmail" placeholder="example@abv.bg" required />
                        </div>
                        <div class="mb-3">
                            <label for="personName" class="form-label">Име на личността</label>
                            <input type="text" class="form-control" id="personName" placeholder="Име на личността" required />
                        </div>
                        <div class="mb-3">
                            <label for="why" class="form-label">Причина за добавяне</label>
                            <textarea class="form-control" id="why" rows="3" placeholder="Защо трябва да я включим?" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-person-plus-fill"></i> Изпрати предложение
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow border-0 h-100">
                <div class="card-body">
                    <h4 class="card-title fw-bold text-center mb-3">📨 Свържи се с нас</h4>
                    <p class="text-muted text-center">Имаш въпрос или предложение? Пиши ни.</p>

                    <form>
                        <div class="mb-3">
                            <label for="contactName" class="form-label">Вашето име</label>
                            <input type="text" class="form-control" id="contactName" placeholder="Име" required />
                        </div>
                        <div class="mb-3">
                            <label for="contactEmail" class="form-label">Имейл</label>
                            <input type="email" class="form-control" id="contactEmail" placeholder="example@abv.bg" required />
                        </div>
                        <div class="mb-3">
                            <label for="contactMessage" class="form-label">Съобщение</label>
                            <textarea class="form-control" id="contactMessage" rows="4" placeholder="Напиши съобщение" required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-send-check-fill"></i> Изпрати съобщение
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
