@model IEnumerable<Biographic.Models.Person>

@{
    ViewData["Title"] = "Търсене на личности";
}

<div class="container my-5">
    <h1 class="text-center text-primary fw-bold mb-4">Търсене на личности</h1>

    <div class="mb-4">
        <input type="text" class="form-control shadow-sm" id="searchBox" placeholder="🔍 Въведете име, държава или професия..." onkeyup="filterCards()" />
    </div>

    <div class="d-flex flex-wrap gap-2 align-items-center justify-content-center mb-4">
        <a asp-action="Index" asp-route-sortOrder="@ViewData["IdSortParm"]" class="btn btn-sm btn-outline-dark shadow-sm">📌 №</a>
        <a asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]" class="btn btn-sm btn-outline-primary shadow-sm">🔄 Име</a>
        <a asp-action="Index" asp-route-sortOrder="@ViewData["CountrySortParm"]" class="btn btn-sm btn-outline-secondary shadow-sm">🌍 Държава</a>
        <a asp-action="Index" asp-route-sortOrder="@ViewData["ProfessionSortParm"]" class="btn btn-sm btn-outline-success shadow-sm">💼 Професия</a>
        <a asp-action="Index" asp-route-sortOrder="@ViewData["BirthYearSortParm"]" class="btn btn-sm btn-outline-warning shadow-sm">🎂 Година на Раждане</a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4" id="personCards">
        @foreach (var item in Model)
        {
            <div class="col person-card">
                <div class="card shadow-sm border-0 rounded h-100">
                    <img src="~/pictures/@(item.ProfileImage)" class="card-img-top" alt="Снимка на @item.Name" style="height: 250px; object-fit: contain;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-center">@item.Name</h5>
                        <p class="card-text"><strong>🌍 Държава:</strong> @item.Country.Name</p>
                        <p class="card-text"><strong>💼 Професия:</strong> @item.Profession.Name</p>
                        <p class="card-text">
                            <strong>🎂 Години:</strong> @item.StartDate.ToShortDateString() -
                            @(item.IsDead ? item.EndDate?.ToShortDateString() : "Настояще")
                        </p>

                        <div class="mt-auto d-grid gap-2">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary">
                                <i class="bi bi-info-circle"></i> Детайли
                            </a>
                            @if (User.Identity?.IsAuthenticated ?? false)
                            {
                                <a asp-area="User" asp-controller="PeopleCatalogs" asp-action="Index" asp-route-personid="@item.Id" class="btn btn-success">
                                    <i class="bi bi-bookmark-heart"></i> Запази в каталог
                                </a>
                            }
                            else
                            {
                                <a asp-area="Identity" asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">
                                    <i class="bi bi-box-arrow-in-right"></i> Влез, за да запазиш
                                </a>
                            }

                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function filterCards() {
            let input = document.getElementById('searchBox').value.toLowerCase();
            let cards = document.querySelectorAll('.person-card');

            cards.forEach(card => {
                let text = card.innerText.toLowerCase();
                card.style.display = text.includes(input) ? 'block' : 'none';
            });
        }
    </script>
}
