@model Biographic.Models.Profession

@{
    ViewData["Title"] = "Изтриване";
}

<div class="container mt-4">
    <h2 class="text-danger fw-bold"><i class="bi bi-trash"></i> Изтрий @Model.Name</h2>
    <hr />

    <div class="alert alert-danger">
        <h5>Сигурни ли сте, че искате да изтриете професията @Model.Name?</h5>
    </div>

    <div class="card p-4 shadow-sm">
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Отказ</a>
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Изтрий</button>
            </div>
        </form>
    </div>
</div>
