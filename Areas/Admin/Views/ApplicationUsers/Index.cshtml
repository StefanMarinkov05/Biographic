@using Biographic.Models
@model IEnumerable<Biographic.Models.ApplicationUser>
@inject UserManager<ApplicationUser> userManager

@{
    ViewData["Title"] = "Потребители";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold text-primary"><i class="bi bi-people"></i> @ViewData["Title"]</h2>
        <a asp-action="Create" class="btn btn-success shadow-sm">
            <i class="bi bi-person-plus-fill"></i> Добави нов потребител
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-hover shadow-sm rounded bg-white align-middle">
            <thead class="table-dark text-center">
                <tr>
                    <th>№</th>
                    <th>Първо име</th>
                    <th>Фамилия</th>
                    <th>Псевдоним</th>
                    <th>Имейл</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    var isAdmin = ViewData["UserRoles"] as Dictionary<string, bool> ?? new Dictionary<string, bool>();
                    var isAdminUser = isAdmin.ContainsKey(item.Id) && isAdmin[item.Id];

                    <tr class="text-center">
                        <td class="align-middle">@item.Id</td>
                        <td class="align-middle">@Html.DisplayFor(modelItem => item.FirstName)</td>
                        <td class="align-middle">@Html.DisplayFor(modelItem => item.LastName)</td>
                        <td class="align-middle">@Html.DisplayFor(modelItem => item.Nickname)</td>
                        <td class="align-middle">@Html.DisplayFor(modelItem => item.Email)</td>
                        <td class="text-end">
                            <div class="d-flex justify-content-center gap-2">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                    ✏️ Редактирай
                                </a>
                                @if (!isAdminUser && item.Id != userManager.GetUserId(User))
                                {
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                        🗑️ Изтрий
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
