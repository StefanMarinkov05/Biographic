@model Biographic.Models.Person

@{
    ViewData["Title"] = "Създай";
}

<h1 class="text-center text-primary fw-bold mb-4">Добави нова личност</h1>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label">Име</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ProfileImage" class="form-label">Снимка</label>
                    <input type="file" name="imageFile" class="form-control" accept=".jpg" />
                    <span asp-validation-for="ProfileImage" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="CountryId" class="form-label">Държава</label>
                    <select asp-for="CountryId" class="form-select" asp-items="ViewBag.CountryId"></select>
                </div>

                <div class="mb-3">
                    <label asp-for="ProfessionId" class="form-label">Професия</label>
                    <select asp-for="ProfessionId" class="form-select" asp-items="ViewBag.ProfessionId"></select>
                </div>

                <div class="mb-3">
                    <label asp-for="Biography" class="form-label">Биография</label>
                    <textarea asp-for="Biography" class="form-control"></textarea>
                    <span asp-validation-for="Biography" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="StartDate" class="form-label">Дата на раждане</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>

                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" asp-for="IsDead" id="isDeadSwitch" />
                    <label class="form-check-label" for="isDeadSwitch">Починал</label>
                </div>

                <div id="endDateGroup" class="mb-3">
                    <label asp-for="EndDate" class="form-label">Дата на смърт</label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> Създай
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left-circle"></i> Назад
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const isDeadCheckbox = document.getElementById('isDeadSwitch');
        const endDateGroup = document.getElementById('endDateGroup');
        const endDateInput = document.querySelector('input[name="EndDate"]');

        function toggleEndDate() {
            if (isDeadCheckbox.checked) {
                endDateGroup.style.display = 'block';
            } else {
                endDateGroup.style.display = 'none';
                endDateInput.value = '';
            }
        }

        isDeadCheckbox.addEventListener('change', toggleEndDate);
        document.addEventListener('DOMContentLoaded', toggleEndDate);
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
