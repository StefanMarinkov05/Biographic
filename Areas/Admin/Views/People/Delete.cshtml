@model Biographic.Models.Person

@{
    ViewData["Title"] = "Изтриване";
}

<div class="container my-5">
    <div class="card shadow border-0">
        <div class="card-body">
            <h1 class="text-center text-danger fw-bold mb-4">Сигурни ли сте, че искате да изтриете @(Model.Name)?</h1>

            <div class="row mb-4">
                <div class="col-md-4 text-center">
                    <img src="~/pictures/@Model.ProfileImage" class="img-fluid rounded shadow-sm" style="max-height: 300px; object-fit: cover;" alt="Снимка на @Model.Name" />
                </div>
                <div class="col-md-8">
                    <dl class="row">
                        <dt class="col-sm-4 fw-bold">Държава</dt>
                        <dd class="col-sm-8">@Model.Country?.Name</dd>

                        <dt class="col-sm-4 fw-bold">Професия</dt>
                        <dd class="col-sm-8">@Model.Profession?.Name</dd>

                        <dt class="col-sm-4 fw-bold">Биография</dt>
                        <dd class="col-sm-8">@Model.Biography</dd>

                        <dt class="col-sm-4 fw-bold">Години</dt>
                        <dd class="col-sm-8">@(Model.StartDate.ToShortDateString()) - @(Model.IsDead ? Model.EndDate?.ToShortDateString() : "Настояще")</dd>
                    </dl>
                </div>
            </div>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />

                <div class="d-flex justify-content-center gap-3">
                    <button type="submit" class="btn btn-danger btn-lg px-4">
                        <i class="bi bi-trash3-fill"></i> Изтрий
                    </button>

                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                        <i class="bi bi-arrow-left-circle"></i> Назад
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
